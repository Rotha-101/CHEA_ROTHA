{
  "entities": {
    "Profile": {
      "title": "Profile",
      "description": "User profile information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "title": { "type": "string" },
        "bio": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "location": { "type": "string" },
        "github": { "type": "string" },
        "linkedin": { "type": "string" },
        "resumeUrl": { "type": "string" },
        "avatarUrl": { "type": "string" }
      }
    },
    "Project": {
      "title": "Project",
      "description": "Portfolio project",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "imageUrl": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["Completed", "In Progress"] },
        "demoUrl": { "type": "string" },
        "githubUrl": { "type": "string" },
        "priority": { "type": "number" }
      },
      "required": ["title", "description"]
    },
    "Experience": {
      "title": "Experience",
      "description": "Work experience",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "company": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "isCurrent": { "type": "boolean" },
        "description": { "type": "string" },
        "logoUrl": { "type": "string" },
        "priority": { "type": "number" }
      },
      "required": ["title", "company", "startDate"]
    },
    "Education": {
      "title": "Education",
      "description": "Educational background",
      "type": "object",
      "properties": {
        "school": { "type": "string" },
        "degree": { "type": "string" },
        "startDate": { "type": "string" },
        "endDate": { "type": "string" },
        "description": { "type": "string" },
        "logoUrl": { "type": "string" },
        "gpa": { "type": "string" }
      },
      "required": ["school", "degree"]
    },
    "Skill": {
      "title": "Skill",
      "description": "Technical or soft skill",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "level": { "type": "number" },
        "category": { "type": "string" },
        "icon": { "type": "string" },
        "priority": { "type": "number" }
      },
      "required": ["name", "category"]
    },
    "BlogPost": {
      "title": "BlogPost",
      "description": "Blog article",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "excerpt": { "type": "string" },
        "imageUrl": { "type": "string" },
        "tags": { "type": "array", "items": { "type": "string" } },
        "status": { "type": "string", "enum": ["draft", "published"] },
        "createdAt": { "type": "string" }
      },
      "required": ["title", "content", "status"]
    }
  },
  "firestore": {
    "/profile/{documentId}": {
      "schema": { "$ref": "#/entities/Profile" },
      "description": "Singleton profile document (id: 'main')"
    },
    "/projects/{projectId}": {
      "schema": { "$ref": "#/entities/Project" },
      "description": "List of projects"
    },
    "/experience/{experienceId}": {
      "schema": { "$ref": "#/entities/Experience" },
      "description": "List of work experiences"
    },
    "/education/{educationId}": {
      "schema": { "$ref": "#/entities/Education" },
      "description": "List of educational background"
    },
    "/skills/{skillId}": {
      "schema": { "$ref": "#/entities/Skill" },
      "description": "List of skills"
    },
    "/blog/{postId}": {
      "schema": { "$ref": "#/entities/BlogPost" },
      "description": "List of blog posts"
    }
  }
}
