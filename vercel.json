{
  "rewrites": [
    {
      "source": "/api/send-email",
      "destination": "/api/send-email"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/save"
    },
    {
      "source": "/uploads/(.*)",
      "destination": "/uploads/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}